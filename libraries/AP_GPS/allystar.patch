+// --- Allystar helpers --------------------------------------------------------
+static inline void allystar_cksum(const uint8_t *p, uint16_t len, uint8_t &cka, uint8_t &ckb)
+{
+    // 8-bit Fletcher über [MessageID..PayloadEnd], Startsequenz F1 D9 ist ausgeschlossen
+    // Referenz: "Packet field description / End Sequence" (CK1, CK2). 
+    // (siehe Allystar Protokoll) 
+    cka = 0; ckb = 0;
+    for (uint16_t i = 0; i < len; i++) { cka += p[i]; ckb += cka; }
+}
+
+// baut und sendet ein Allystar-CFG-MSG Paket: Klasse, ID, Period(U1)
+void AP_GPS_NMEA::allystar_send_cfg_msg(uint8_t cls, uint8_t id, uint8_t period)
+{
+    // Struktur: F1 D9  06 01  03 00  [cls id period]  CK_A CK_B
+    uint8_t buf[4 /*hdr*/ + 2 /*len*/ + 3 /*payload*/ + 2 /*ck*/];
+    uint8_t *w = buf;
+    *w++ = 0xF1; *w++ = 0xD9; // Start
+    *w++ = 0x06; *w++ = 0x01; // CFG-MSG
+    *w++ = 0x03; *w++ = 0x00; // Length = 3 (LE)
+    *w++ = cls;  *w++ = id;   // Payload
+    *w++ = period;
+    // Checksum über [MessageID..Payload]
+    uint8_t ck_a, ck_b;
+    allystar_cksum(&buf[2], 4 /*msg id*/ + 2 /*len*/ + 3 /*payload*/, ck_a, ck_b);
+    *w++ = ck_a; *w++ = ck_b;
+    port->write(buf, sizeof(buf));
+}
